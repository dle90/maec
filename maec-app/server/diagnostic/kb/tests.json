  {
    "_id": "t-va",
    "name": "Visual acuity (VA)",
    "nameVi": "Đo thị lực",
    "services": ["optical", "sensor", "transport"],
    "expensive": false,
    "invasiveness": "none",
    "availableInClinic": true,
    "svcCode": "SVC-REFRACT",
    "producesFindings": ["va_reduced", "va_severe_loss", "va_corrects_with_refraction"],
    "harmIfSkipped": 5,
    "measurements": [
      {
        "key": "ucva",
        "label": "UCVA (uncorrected)",
        "labelVi": "Thị lực không kính (thập phân)",
        "unit": "decimal",
        "valueType": "number",
        "perEye": true,
        "min": 0,
        "max": 2,
        "step": 0.05,
        "derives": []
      },
      {
        "key": "bcva",
        "label": "BCVA (best-corrected)",
        "labelVi": "Thị lực với kính (thập phân)",
        "unit": "decimal",
        "valueType": "number",
        "perEye": true,
        "min": 0,
        "max": 2,
        "step": 0.05,
        "derives": [
          {
            "op": "<",
            "value": 0.5,
            "finding": "va_reduced"
          },
          {
            "op": "<=",
            "value": 0.1,
            "finding": "va_severe_loss"
          }
        ]
      },
      {
        "key": "va_gain",
        "label": "Correction gain (BCVA − UCVA)",
        "labelVi": "Mức cải thiện với kính",
        "unit": "decimal",
        "valueType": "computed",
        "compute": "va_correction_gain",
        "computeFrom": ["bcva", "ucva"],
        "perEye": true,
        "input": false,
        "derives": [
          {
            "op": ">=",
            "value": 0.2,
            "finding": "va_corrects_with_refraction"
          }
        ]
      }
    ]
  },
