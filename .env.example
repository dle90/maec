# Server
PORT=3001

# MongoDB
MONGODB_URI=mongodb://localhost:27017/maec

# PACS - Orthanc server (internal)
ORTHANC_URL=http://localhost:8042

# OHIF Viewer (public URL browser uses)
OHIF_URL=http://localhost:3000

# Cloudflare R2 — encounter file attachments (PDFs, images).
# Without these, attachment uploads/views return a clean 503 and the rest
# of the app keeps working. See maec-app/server/lib/r2.js.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=maec-attachments
